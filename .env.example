# Consumed by `docker compose up` for the `api` service. Copy to .env (gitignored)
# and fill in real values for a `docker compose up` dev loop.
#
# For plain `dotnet run` against the backend instead, config comes from
# backend/src/DonkeyWork.A2AExplorer.Api/appsettings.Development.json (also gitignored).

# Client secret issued by Keycloak for the `a2a-explorer` client under realm `Agents`.
KEYCLOAK_CLIENT_SECRET=

# Symmetric key passed to pgcrypto pgp_sym_encrypt/decrypt. Any string 16+ chars.
SECURITY_ENCRYPTION_KEY=
